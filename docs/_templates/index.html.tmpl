<!doctype html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{index.title}}</title>
    <style>
      :root {
        --bg: #0f0f1a;
        --surface: #1a1a2e;
        --border: #0f3460;
        --primary: #e94560;
        --text: #eee;
        --text-muted: #8892a4;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
      }
      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      h1 {
        font-size: 2.5rem;
        margin-bottom: 8px;
      }
      .tagline {
        color: var(--text-muted);
        font-size: 1.1rem;
        margin-bottom: 32px;
      }
      h2 {
        font-size: 1.4rem;
        margin: 32px 0 12px;
        color: var(--primary);
      }
      h3 {
        font-size: 1.1rem;
        margin: 20px 0 8px;
      }
      p,
      li {
        color: var(--text-muted);
      }
      ul {
        padding-left: 24px;
        margin-bottom: 16px;
      }
      li {
        margin-bottom: 4px;
      }
      a {
        color: var(--primary);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
      }
      .flow {
        font-family: monospace;
        color: var(--text);
        margin: 12px 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 12px 0;
      }
      th,
      td {
        text-align: left;
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
      }
      th {
        color: var(--text);
        font-size: 0.9rem;
      }
      td {
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      .footer {
        margin-top: 48px;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.85rem;
      }
      .nav {
        margin-bottom: 32px;
      }
      .nav a {
        margin-right: 16px;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Hush Meet</h1>
      <p class="tagline">
        {{index.tagline}}
      </p>

      <nav class="nav">
        <a href="privacy-policy.html">{{index.nav_privacy}}</a>
        <a href="architecture.html">{{index.nav_tech_docs}}</a>
        <a href="https://github.com/s-hiraoku/hush-meet">GitHub</a>
        {{nav_lang_links}}
      </nav>

      <h2>{{index.features_title}}</h2>
      <div class="card">
        <ul>
          <li>{{index.feature_auto_mute}}</li>
          <li>
            {{index.feature_4_modes}}
            <ul>
              <li><strong>{{index.mode_off}}</strong> &mdash; {{index.mode_off_desc}}</li>
              <li>
                <strong>{{index.mode_auto}}</strong> &mdash; {{index.mode_auto_desc}}
              </li>
              <li>
                <strong>{{index.mode_auto_off}}</strong> &mdash; {{index.mode_auto_off_desc}}
              </li>
              <li><strong>{{index.mode_ptt}}</strong> &mdash; {{index.mode_ptt_desc}}</li>
            </ul>
          </li>
          <li>
            {{index.feature_mic_button}}
          </li>
          <li>
            {{index.feature_shortcut}}
          </li>
          <li>{{index.feature_independent_audio}}</li>
          <li>{{index.feature_noise_gate}}</li>
          <li>{{index.feature_asymmetric}}</li>
          <li>{{index.feature_meter}}</li>
          <li>{{index.feature_sensitivity}}</li>
          <li>
            {{index.feature_manual_mute}}
          </li>
          <li>{{index.feature_mic_selector}}</li>
          <li>{{index.feature_themes}}</li>
          <li>{{index.feature_toolbar_icon}}</li>
          <li>{{index.feature_language}}</li>
          <li>
            {{index.feature_games}}
          </li>
        </ul>
      </div>

      <h2>{{index.how_it_works_title}}</h2>
      <div class="card">
        <div class="flow">
          {{index.how_it_works_flow}}
        </div>
        <p>
          {{index.how_it_works_desc}}
        </p>
      </div>

      <h2>{{index.settings_title}}</h2>
      <div class="card">
        <table>
          <tr>
            <th>{{index.settings_col_setting}}</th>
            <th>{{index.settings_col_description}}</th>
            <th>{{index.settings_col_default}}</th>
          </tr>
          <tr>
            <td>{{index.setting_mode}}</td>
            <td>{{index.setting_mode_desc}}</td>
            <td>{{index.setting_mode_default}}</td>
          </tr>
          <tr>
            <td>{{index.setting_shortcut}}</td>
            <td>{{index.setting_shortcut_desc}}</td>
            <td>{{index.setting_shortcut_default}}</td>
          </tr>
          <tr>
            <td>{{index.setting_sensitivity}}</td>
            <td>{{index.setting_sensitivity_desc}}</td>
            <td>0.025</td>
          </tr>
          <tr>
            <td>{{index.setting_grace}}</td>
            <td>{{index.setting_grace_desc}}</td>
            <td>{{index.setting_grace_default}}</td>
          </tr>
          <tr>
            <td>{{index.setting_mic}}</td>
            <td>{{index.setting_mic_desc}}</td>
            <td>{{index.setting_mic_default}}</td>
          </tr>
          <tr>
            <td>{{index.setting_theme}}</td>
            <td>{{index.setting_theme_desc}}</td>
            <td>{{index.setting_theme_default}}</td>
          </tr>
          <tr>
            <td>{{index.setting_language}}</td>
            <td>{{index.setting_language_desc}}</td>
            <td>{{index.setting_language_default}}</td>
          </tr>
        </table>
      </div>

      <h2>{{index.manual_mute_title}}</h2>
      <div class="card">
        <p>
          {{index.manual_mute_desc}}
        </p>
        <ul>
          <li>{{index.manual_mute_observer}}</li>
          <li>{{index.manual_mute_distinguish}}</li>
          <li>{{index.manual_mute_tracking}}</li>
          <li>{{index.manual_mute_mode}}</li>
        </ul>
      </div>

      <h2>{{index.getting_started_title}}</h2>
      <div class="card">
        <ol style="padding-left: 24px; color: var(--text-muted)">
          <li>{{index.getting_started_1}}</li>
          <li>{{index.getting_started_2}}</li>
          <li>{{index.getting_started_3}}</li>
          <li>{{index.getting_started_4}}</li>
          <li>{{index.getting_started_5}}</li>
          <li>{{index.getting_started_6}}</li>
          <li>{{index.getting_started_7}}</li>
        </ol>
      </div>

      <h2>{{index.tech_stack_title}}</h2>
      <div class="card">
        <ul>
          <li>Chrome Extension Manifest V3</li>
          <li>React 19 + TypeScript</li>
          <li>Vite + CRXJS Vite Plugin</li>
          <li>Web Audio API (AnalyserNode)</li>
          <li>Chrome Storage API</li>
        </ul>
      </div>

      <div class="footer">
        <p>&copy; 2026 Hush Meet. <a href="https://github.com/s-hiraoku/hush-meet">GitHub</a></p>
      </div>
    </div>
  </body>
</html>
