<!doctype html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{privacy.title}} - Hush Meet</title>
    <style>
      :root {
        --bg: #0f0f1a;
        --surface: #1a1a2e;
        --border: #0f3460;
        --primary: #e94560;
        --text: #eee;
        --text-muted: #8892a4;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
      }
      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 8px;
      }
      h2 {
        font-size: 1.3rem;
        margin: 28px 0 12px;
        color: var(--primary);
      }
      p {
        color: var(--text-muted);
        margin-bottom: 12px;
      }
      ul {
        padding-left: 24px;
        margin-bottom: 16px;
      }
      li {
        color: var(--text-muted);
        margin-bottom: 4px;
      }
      a {
        color: var(--primary);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .back {
        margin-bottom: 24px;
        display: inline-block;
        font-size: 0.9rem;
      }
      .updated {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-bottom: 24px;
      }
      .footer {
        margin-top: 48px;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <a href="{{privacy.back_link}}" class="back">&larr; {{privacy.back}}</a>
      <h1>{{privacy.title}}</h1>
      <p class="updated">{{privacy.updated}}</p>

      <h2>{{privacy.overview_title}}</h2>
      <p>
        {{privacy.overview_text}}
      </p>

      <h2>{{privacy.data_collection_title}}</h2>
      <p><strong>{{privacy.data_collection_text}}</strong></p>

      <h2>{{privacy.mic_access_title}}</h2>
      <p>
        {{privacy.mic_access_text}}
      </p>
      <ul>
        <li>{{privacy.mic_realtime}}</li>
        <li>{{privacy.mic_no_record}}</li>
        <li>{{privacy.mic_no_server}}</li>
        <li>{{privacy.mic_rms_only}}</li>
      </ul>

      <h2>{{privacy.local_storage_title}}</h2>
      <p>{{privacy.local_storage_text}}</p>
      <ul>
        <li>{{privacy.storage_mode}}</li>
        <li>{{privacy.storage_sensitivity}}</li>
        <li>{{privacy.storage_grace}}</li>
        <li>{{privacy.storage_shortcut}}</li>
        <li>{{privacy.storage_mic}}</li>
        <li>{{privacy.storage_theme_lang}}</li>
      </ul>
      <p>{{privacy.local_storage_note}}</p>

      <h2>{{privacy.website_access_title}}</h2>
      <p>
        {{privacy.website_access_text}}
      </p>

      <h2>{{privacy.third_party_title}}</h2>
      <p>
        {{privacy.third_party_text}}
      </p>

      <h2>{{privacy.open_source_title}}</h2>
      <p>
        {{privacy.open_source_text}}
      </p>

      <h2>{{privacy.contact_title}}</h2>
      <p>
        {{privacy.contact_text}}
      </p>

      <h2>{{privacy.changes_title}}</h2>
      <p>
        {{privacy.changes_text}}
      </p>

      <div class="footer">
        <p>&copy; 2026 Hush Meet. <a href="https://github.com/s-hiraoku/hush-meet">GitHub</a></p>
      </div>
    </div>
  </body>
</html>
